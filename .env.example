# ASAN Macro application
# Keep API keys out of code; use .env or Colab secrets
OPENAI_API_KEY=your_openai_api_key_here
# Optional: use when OpenAI quota exceeded (free key at https://aistudio.google.com/apikey)
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional: UN Comtrade (live data). Get key at https://comtradedeveloper.un.org/
# COMTRADE_API_KEY=your_comtrade_key_here
# COMTRADE_BASE_URL=https://comtradeplus.un.org/api/get

# Local open-source model (no API key, no quota): install Ollama from https://ollama.com then:
# USE_LOCAL_LLM=1
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1
